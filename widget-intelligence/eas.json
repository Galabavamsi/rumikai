{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "sdk-54"
      },
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "sdk-54"
      },
      "ios": { "distribution": "internal" }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "image": "sdk-54"
      },
      "ios": { "distribution": "store" }
    }
  }
}
